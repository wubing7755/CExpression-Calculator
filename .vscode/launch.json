{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Calculator (No Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Build"
    },
    {
      "name": "Calculator (Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": ["--debug"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Build (Debug Mode)"
    }
  ]
}
